# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# --- Service ---
ENVIRONMENT=production
API_PREFIX=/api/v1
# Comma-separated origins, or * (the iOS app calls server-to-server, so * is fine).
CORS_ALLOW_ORIGINS=*

# --- Primary LLM provider: nan.builders (EU, zero prompt logging) ---
# OpenAI-compatible /chat/completions endpoint.
PRIMARY_BASE_URL=https://api.nan.builders/v1
PRIMARY_API_KEY=
# Comma-separated model chain (tried in order) before the OpenAI fallback below.
PRIMARY_MODEL_TEXT=gemma4,qwen3.6
PRIMARY_MODEL_VISION=gemma4,qwen3.6

# --- Fallback LLM provider: OpenAI ---
FALLBACK_BASE_URL=https://api.openai.com/v1
FALLBACK_API_KEY=
FALLBACK_MODEL_TEXT=gpt-4o-mini
FALLBACK_MODEL_VISION=gpt-4o-mini

LLM_TIMEOUT_SECONDS=60
LLM_MAX_OUTPUT_TOKENS=4096
# Route statements that split into MORE than N chunks straight to OpenAI first (primary kept as
# backup). 0 = off (default). The benchmark didn't justify turning it on; the mechanism stays for
# data-driven tuning from request_log. See scripts/bench_llm.py and app/config.py.
PARSE_LARGE_ROUTE_CHUNKS=0
# Debug only: log the model's raw output (truncated) when it returns unparseable JSON
# (LLMBadOutput). Off by default — the raw output is user data. Set to true to diagnose, then revert.
LLM_DEBUG_RAW=false
LLM_DEBUG_RAW_CHARS=4000

# --- MySQL (cache + rate limit + operational logging; NO user data) ---
# Leave empty to run without a database (everything degrades gracefully).
DATABASE_URL=mysql+pymysql://spendscope:CHANGE_ME@127.0.0.1:3306/spendscope?charset=utf8mb4

CACHE_ENABLED=true
CACHE_TTL_SECONDS=2592000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# --- RevenueCat (premium gate for /enrich) ---
# Use the server SECRET key (sk_...), NOT the public iOS key (appl_...).
REQUIRE_PREMIUM=true
REVENUECAT_SECRET_KEY=
REVENUECAT_ENTITLEMENT_ID=premium

# Tolerance (fraction) when checking the parsed receipt total against the transaction amount.
ENRICH_TOTAL_TOLERANCE=0.05
